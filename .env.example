ESET_BASE_URL=https://eu.incident-management.eset.systems
ESET_AUTH_URL=https://eu.business-account.iam.eset.systems/oauth/token
ESET_USERNAME=
ESET_PASSWORD=
ESET_CLIENT_ID=
ESET_CLIENT_SECRET=
# Optional local-only token override for short-lived API testing.
# Prefer client credentials in normal operation.
ESET_ACCESS_TOKEN=
ESET_ACCESS_TOKEN_EXPIRES_IN=3600
ESET_POLL_INTERVAL_SECONDS=300
ESET_PAGE_SIZE=100
INCIDENT_NOTIFY_LIMIT=10
INCIDENT_NOTIFY_CRON_HOUR=10
INCIDENT_NOTIFY_CRON_MINUTE=0
INCIDENT_NOTIFY_TIMEZONE=Asia/Seoul

DATABASE_URL=postgresql+psycopg://incident_ai:change-me@postgres:5432/incident_ai
POSTGRES_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0
REDIS_PASSWORD=change-me

DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=false

LLM_PROVIDER=ollama
LLM_MODEL=
# Leave OLLAMA_MODEL empty to fall back to the local deterministic gateway.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_KEEP_ALIVE=0s
LLM_TIMEOUT_SECONDS=240
LLM_MAX_RETRIES=2
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

SANITIZER_HMAC_SECRET=change-me-in-secret-manager
